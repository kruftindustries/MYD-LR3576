+	struct jaguar2 *jaguar2 = to_jaguar2(sd);
+	struct i2c_client *client = jaguar2->client;
+	int i, ch;
+
+	mutex_lock(&jaguar2->mutex);
+
+	if (jaguar2->streaming) {
+		mutex_unlock(&jaguar2->mutex);
+		return -EBUSY;
+	}
+
+	for (i = 0; i < ARRAY_SIZE(jaguar2_dv_timings); i++) {
+		if (v4l2_match_dv_timings(timings,
+					  &jaguar2_dv_timings[i].timings,
+					  250000, false)) {
+			int j;
+
+			*timings = jaguar2_dv_timings[i].timings;
+			jaguar2->timings = *timings;
+
+			/* Update per-channel state to forced format */
+			for (ch = 0; ch < 4; ch++) {
+				jaguar2->ch_state[ch].active_fmt =
+					jaguar2_dv_timings[i].fmt_idx;
+				jaguar2->ch_state[ch].force_fmt = true;
+			}
+
+			/*
+			 * Update frame_size and mbus format to match the
+			 * DV timings so get_fmt/set_fmt/s_stream use the
+			 * correct resolution.
+			 */
+			for (j = 0; j < ARRAY_SIZE(jaguar2_framesizes); j++) {
+				if (jaguar2_framesizes[j].fmt_idx ==
+				    jaguar2_dv_timings[i].fmt_idx) {
+					jaguar2->frame_size =
+						&jaguar2_framesizes[j];
+					break;
+				}
+			}
+			jaguar2->format.width =
+				jaguar2->frame_size->width;
+			jaguar2->format.height =
+				jaguar2->frame_size->height;
+			jaguar2->format.field =
+				jaguar2->frame_size->field;
+
+			dev_info(&client->dev,
+				 "s_dv_timings: forced %s (fmt=%d) %ux%u",
+				 jaguar2_dv_timings[i].name,
+				 jaguar2_dv_timings[i].fmt_idx,
+				 jaguar2->frame_size->width,
+				 jaguar2->frame_size->height);
+
+			mutex_unlock(&jaguar2->mutex);
+
+			/*
+			 * Program the decoder registers so color bars
+			 * and NOVID detection match the new format.
+			 * Must be done outside mutex (probe_format
+			 * takes jaguar2_lock for GPIO I2C).
+			 */
+			for (ch = 0; ch < 4; ch++)
+				jaguar2_probe_format(ch,
+					jaguar2_dv_timings[i].fmt_idx,
+					SINGLE_ENDED);
+
+			return 0;
+		}
+	}
+
+	mutex_unlock(&jaguar2->mutex);
+	return -EINVAL;
+}
+
+static int jaguar2_enum_dv_timings(struct v4l2_subdev *sd,
+				   struct v4l2_enum_dv_timings *timings)
+{
+	if (timings->index >= ARRAY_SIZE(jaguar2_dv_timings))
+		return -EINVAL;
+
+	timings->timings = jaguar2_dv_timings[timings->index].timings;
+	return 0;
+}
+
+static int jaguar2_dv_timings_cap(struct v4l2_subdev *sd,
+				  struct v4l2_dv_timings_cap *cap)
+{
+	*cap = jaguar2_timings_cap;
+	return 0;
+}
+
+/* ---- V4L2 Events ---- */
+
+static int jaguar2_subscribe_event(struct v4l2_subdev *sd,
+				   struct v4l2_fh *fh,
+				   struct v4l2_event_subscription *sub)
+{
+	switch (sub->type) {
+	case V4L2_EVENT_SOURCE_CHANGE:
+		return v4l2_src_change_event_subdev_subscribe(sd, fh, sub);
+	case V4L2_EVENT_CTRL:
+		return v4l2_ctrl_subdev_subscribe_event(sd, fh, sub);
+	case V4L2_EVENT_MOTION_DET:
+		return v4l2_event_subscribe(fh, sub, 0, NULL);
+	default:
+		return -EINVAL;
+	}
+}
+
+/* ---- Motion Detection Controls ---- */
+
+static int jaguar2_s_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct jaguar2 *jaguar2 =
+		container_of(ctrl->handler, struct jaguar2, ctrl_handler);
+	struct i2c_client *client = jaguar2->client;
+	motion_mode ms;
+	int ch;
+
+	memset(&ms, 0, sizeof(ms));
+	ms.devnum = 0;
+
+	switch (ctrl->id) {
+	case V4L2_CID_DETECT_MD_MODE:
+		down(&jaguar2_lock);
+		for (ch = 0; ch < 4; ch++) {
+			ms.ch = ch;
+			if (ctrl->val == V4L2_DETECT_MD_MODE_DISABLED) {
+				ms.set_val = FUNC_OFF;
+				motion_onoff_set2(&ms);
+				jaguar2->md_enabled = false;
+			} else {
+				ms.set_val = FUNC_ON;
+				motion_onoff_set2(&ms);
+				if (ctrl->val == V4L2_DETECT_MD_MODE_GLOBAL) {
+					ms.set_val = 0xFF;
+					motion_pixel_all_onoff_set2(&ms);
+				}
+				jaguar2->md_enabled = true;
+			}
+		}
+		up(&jaguar2_lock);
+		dev_info(&client->dev, "MD mode=%d", ctrl->val);
+		break;
+
+	case V4L2_CID_DETECT_MD_GLOBAL_THRESHOLD:
+		down(&jaguar2_lock);
+		for (ch = 0; ch < 4; ch++) {
+			ms.ch = ch;
+			ms.set_val = ctrl->val;
+			motion_tsen_set2(&ms);
+		}
+		up(&jaguar2_lock);
+		dev_info(&client->dev, "MD threshold=%d", ctrl->val);
+		break;
+
+	case V4L2_CID_JAGUAR2_PSEN:
+		down(&jaguar2_lock);
+		for (ch = 0; ch < 4; ch++) {
+			ms.ch = ch;
+			ms.set_val = ctrl->val;
+			motion_psen_set2(&ms);
+		}
+		up(&jaguar2_lock);
+		dev_info(&client->dev, "MD PSEN=%d", ctrl->val);
+		break;
+
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}

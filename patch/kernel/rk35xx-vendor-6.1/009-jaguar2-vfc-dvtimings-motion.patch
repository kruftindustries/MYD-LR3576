+/*
+ * Auto-detect camera format per-channel via register probing.
+ * For each channel 0-3, tries the previous format first, then probes
+ * all supported formats checking for sync lock.  Updates ch_state[]
+ * individually.  Sets global frame_size/format/timings from the first
+ * channel with signal (for mbus negotiation with rkcif).
+ * Called with jaguar2->mutex held.
+ * Returns true if at least one channel detected a format.
+ */
+static bool jaguar2_auto_detect_format(struct jaguar2 *jaguar2)
+{
+	struct i2c_client *client = jaguar2->client;
+	int ch, pi, j;
+	bool any_detected = false;
+	bool any_probed = false;
+	int primary_dv_idx = -1;
+
+	/* Ensure chip is powered on (runtime PM may have suspended it) */
+	if (!jaguar2->power_on) {
+		if (__jaguar2_power_on(jaguar2) < 0)
+			return false;
+		usleep_range(40000, 50000);
+		jaguar2->power_on = true;
+	}
+
+	/*
+	 * Enable NOVID detection for all channels (boot-time
+	 * vd_vi_manual_set_seq1() disables it).
+	 *
+	 * Do NOT disable the MIPI TX arbiter here: s_stream is
+	 * called after the CIF DMA engine is already running.
+	 * Disabling the arbiter would starve the CIF of MIPI data,
+	 * causing hundreds of thousands of zero-size CSI_SIZE_ERR
+	 * interrupts that leave the IOMMU with pending page faults
+	 * and crash rk_iommu_disable() on stream stop.
+	 *
+	 * jaguar2_probe_format() only configures decoder registers
+	 * (AFE/timing/EQ) without touching MIPI output, so the
+	 * arbiter can stay active during probing.  Brief format-
+	 * transition glitches produce occasional CSI_SIZE_ERR
+	 * which patch 005 handles gracefully.
+	 */
+	down(&jaguar2_lock);
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x00);
+	for (ch = 0; ch < 4; ch++)
+		gpio_i2c_write(jaguar2_i2c_addr[0], 0x18 + ch, 0x13);
+	up(&jaguar2_lock);
+
+	/* NOVID detection needs time to settle after being enabled */
+	msleep(50);
+
+	for (ch = 0; ch < 4; ch++) {
+		u8 prev_fmt = jaguar2->ch_state[ch].active_fmt;
+		u8 nosig, sync_v, hperiod;
+		bool found = false;
+		bool probed = false;
+		int found_dv_idx = -1;
+
+		/*
+		 * Fast path: check if current config already matches
+		 * the connected signal.  Just read status registers
+		 * without reconfiguring the decoder (~0ms).
+		 */
+		down(&jaguar2_lock);
+		gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x00);
+		nosig = gpio_i2c_read(jaguar2_i2c_addr[0], 0xA0);
+		sync_v = gpio_i2c_read(jaguar2_i2c_addr[0],
+				       0xD0 + ch);
+		hperiod = gpio_i2c_read(jaguar2_i2c_addr[0],
+					0xD8 + ch);
+		up(&jaguar2_lock);
+
+		if (nosig != 0xFA && sync_v != 0xFA &&
+		    !(nosig & (1 << ch)) && sync_v && hperiod) {
+			/* Current format matches — find DV timings entry */
+			for (j = 0; j < ARRAY_SIZE(jaguar2_dv_timings); j++) {
+				if (jaguar2_dv_timings[j].fmt_idx == prev_fmt) {
+					found_dv_idx = j;
+					break;
+				}
+			}
+			found = true;
+			dev_info(&client->dev,
+				 "auto-detect ch%d: current fmt=%d OK",
+				 ch, prev_fmt);
+			goto ch_done;
+		}
+
+		/*
+		 * Quick no-signal check: if nosig bit is set AND at
+		 * least one other channel has signal, this channel
+		 * likely has no camera.  Skip the expensive probe.
+		 *
+		 * But if ALL channels show no-signal (0x0F), the
+		 * current decoder format class may be wrong (e.g.
+		 * AHD mode can't detect CVBS cameras via NOVID).
+		 * Fall through to full probe in that case.
+		 */
+		if ((nosig & (1 << ch)) && (nosig & 0x0F) != 0x0F) {
+			dev_info(&client->dev,
+				 "auto-detect ch%d: no signal (nosig=0x%02x)",
+				 ch, nosig);
+			goto ch_done;
+		}
+		{
+			/*
+			 * When all channels show no-signal, the current
+			 * format class is likely wrong (e.g. AHD mode
+			 * cannot detect CVBS).  Must try ALL formats —
+			 * nosig_streak early-exit would miss cross-class.
+			 */
+			bool all_nosig = (nosig & 0x0F) == 0x0F;
+
+			if (all_nosig)
+				dev_info(&client->dev,
+					 "auto-detect ch%d: all-nosig, probing formats",
+					 ch);
+		}
+
+		/*
+		 * Signal present but format mismatch.  Probe formats in
+		 * priority order with 200ms settle time (CVBS needs
+		 * ~150ms for sync separator stabilization).
+		 * Skip the current format (already checked).
+		 * After 2 consecutive no-signal results, assume empty
+		 * channel and stop probing (disabled for all-nosig
+		 * cross-format mode).
+		 */
+		probed = true;
+		any_probed = true;
+		{
+			bool all_nosig = (nosig & 0x0F) == 0x0F;
+			int nosig_streak = 0;
+
+			for (pi = 0; pi < ARRAY_SIZE(jaguar2_probe_order); pi++) {
+				int idx = jaguar2_probe_order[pi];
+				u8 fmt = jaguar2_dv_timings[idx].fmt_idx;
+
+				if (fmt == prev_fmt)
+					continue;
+
+				jaguar2_probe_format(ch, fmt, SINGLE_ENDED);
+				msleep(200);
+
+				down(&jaguar2_lock);
+				gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF,
+					       0x00);
+				nosig = gpio_i2c_read(jaguar2_i2c_addr[0],
+						      0xA0);
+				sync_v = gpio_i2c_read(jaguar2_i2c_addr[0],
+						       0xD0 + ch);
+				hperiod = gpio_i2c_read(jaguar2_i2c_addr[0],
+							0xD8 + ch);
+				up(&jaguar2_lock);
+
+				if (nosig == 0xFA || sync_v == 0xFA)
+					continue;

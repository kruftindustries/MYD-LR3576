+static int jaguar2_query_dv_timings(struct v4l2_subdev *sd,
+				    struct v4l2_dv_timings *timings)
+{
+	struct jaguar2 *jaguar2 = to_jaguar2(sd);
+
+	mutex_lock(&jaguar2->mutex);
+	if (jaguar2_auto_detect_format(jaguar2)) {
+		*timings = jaguar2->timings;
+		mutex_unlock(&jaguar2->mutex);
+		return 0;
+	}
+	mutex_unlock(&jaguar2->mutex);
+	return -ENOLINK;
+}
+
+static int jaguar2_g_dv_timings(struct v4l2_subdev *sd,
+				struct v4l2_dv_timings *timings)
+{
+	struct jaguar2 *jaguar2 = to_jaguar2(sd);
+
+	mutex_lock(&jaguar2->mutex);
+	*timings = jaguar2->timings;
+	mutex_unlock(&jaguar2->mutex);
+
+	return 0;
+}

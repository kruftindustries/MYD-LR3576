 }
 
+/*
+ * Lightweight format probe: configure decoder for a format without
+ * touching MIPI output or arbiter. Used by query_dv_timings to test
+ * each format for sync lock without destabilizing the chip.
+ * Caller must NOT hold jaguar2_lock.
+ */
+void jaguar2_probe_format(int ch, unsigned char fmt, int input)
+{
+	video_input_init video_val;
+
+	video_val.ch = ch;
+	video_val.format = fmt;
+	video_val.input = input;
+	video_val.interface = YUV_422;
+
+	down(&jaguar2_lock);
+
+	vd_jaguar2_init_set(&video_val);
+
+	/* Restore NOVID detection for this channel */
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x00);
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x18 + ch, 0x13);
+
+	up(&jaguar2_lock);
+}
+
+/*
+ * Re-enable VFC (Video Format Check) auto-detection on a channel.
+ * The init sequence (vd_vi_manual_set_seq1) disables VFC by clearing
+ * Bank 0x13 regs 0x30-0x32 and Bank 0x01 reg 0x7C clock auto bits.
+ * This reverses that to allow the hardware to detect the input format.
+ * Caller must hold jaguar2_lock.
+ */
+void jaguar2_vfc_enable(int ch)
+{
+	unsigned char val;
+
+	/*
+	 * Reset format registers to neutral/auto so VFC can detect
+	 * any input type (AHD or CVBS). The manual init sets these
+	 * for a specific format which prevents VFC from detecting
+	 * a different input type (e.g., CVBS when configured for AHD).
+	 */
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x00);
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x08 + ch, 0x00); /* AHD_MODE = auto */
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x04 + ch, 0x00); /* SD_MODE = auto */
+
+	/* Clock auto-select: Bank 0x01 reg 0x7C */
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x01);
+	val = gpio_i2c_read(jaguar2_i2c_addr[0], 0x7C);
+	val |= (1 << ch);
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x7C, val);
+
+	/* Bank 0x13 regs 0x30-0x32: enable VFC detection */
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x13);
+
+	val = gpio_i2c_read(jaguar2_i2c_addr[0], 0x30);
+	val |= (1 << ch) | (1 << (ch + 4));
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x30, val);
+
+	val = gpio_i2c_read(jaguar2_i2c_addr[0], 0x31);
+	val |= (1 << ch) | (1 << (ch + 4));
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x31, val);
+
+	val = gpio_i2c_read(jaguar2_i2c_addr[0], 0x32);
+	val |= (1 << ch);
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0x32, val);
+}
+
+/*
+ * Read VFC detected format from Bank 0x05+ch, reg 0xF0.
+ * Returns raw byte: 0xFF = no video, other = detected format code.
+ * Pattern from jaguar2_coax_protocol.c:1273-1274.
+ * Caller must hold jaguar2_lock.
+ */
+u8 jaguar2_vfc_read(int ch)
+{
+	gpio_i2c_write(jaguar2_i2c_addr[0], 0xFF, 0x05 + ch);
+	return gpio_i2c_read(jaguar2_i2c_addr[0], 0xF0);
+}
+
+/*
+ * Map VFC auto-detect register value to NC_VIVO_CH_FORMATDEF.
+ * Values correspond to ahd_mode field in jaguar2_video_table.h.
+ * SD/CVBS uses separate VFC codes (0x21=PAL, 0x22=NTSC).
+ */
+u8 jaguar2_vfc_to_formatdef(u8 vfc_val)
+{
+	switch (vfc_val) {
+	case 0x02: return AHD20_1080P_30P;
+	case 0x03: return AHD20_1080P_25P;
+	case 0x04: return AHD20_720P_60P;
+	case 0x05: return AHD20_720P_50P;
+	case 0x06: return AHD20_720P_30P;
+	case 0x0A: return AHD20_720P_30P_EX;
+	case 0x0B: return AHD20_720P_25P_EX;
+	case 0x0C: return AHD20_720P_30P_EX_Btype;
+	case 0x0D: return AHD20_720P_25P_EX_Btype;
+	case 0x21: return AHD20_SD_H960_2EX_Btype_PAL;
+	case 0x22: return AHD20_SD_H960_2EX_Btype_NT;
+	case 0xFA: return AHD20_SD_H960_2EX_Btype_PAL;
+	case 0xFB: return AHD20_SD_H960_2EX_Btype_NT;
+	case 0xFF: return NC_VIVO_CH_FORMATDEF_UNKNOWN;
+	default:
+		printk(KERN_WARNING "VFC: unknown format code 0x%02x\n",
+		       vfc_val);
+		return NC_VIVO_CH_FORMATDEF_UNKNOWN;
+	}
+}

From: Nick <nick@local>
Subject: [PATCH] media: jaguar2: add jaguar2_active param to mask arbiter channels

The NVP6324 MIPI TX arbiter outputs data for all enabled channels even
when no camera is connected, consuming MIPI CSI-2 bandwidth and starving
channels that have active video input. Neither the video loss registers
nor the AGC lock registers reliably distinguish connected from
unconnected cameras on this chip.

Add a jaguar2_active module parameter (bitmask, default 0xF = all) to
specify which channels have cameras. arb_enable2() uses this mask to
only enable the corresponding arbiter channels. The parameter is
writable at runtime via sysfs.

Usage: echo 4 > /sys/module/jaguar2/parameters/jaguar2_active

Signed-off-by: Nick <nick@local>
---
diff --git a/drivers/media/i2c/jaguar2_drv/jaguar2_common.h b/drivers/media/i2c/jaguar2_drv/jaguar2_common.h
--- a/drivers/media/i2c/jaguar2_drv/jaguar2_common.h
+++ b/drivers/media/i2c/jaguar2_drv/jaguar2_common.h
@@ -26,6 +26,7 @@
 #define JAGUAR1_MAX_CHAN_CNT 4
 
 extern unsigned int jaguar2_i2c_addr[4];
+extern unsigned int jaguar2_active;
 
 #define HI_CHIPID_BASE 0x12050000
 #define HI_CHIPID0 IO_ADDRESS(HI_CHIPID_BASE + 0xEEC)
diff --git a/drivers/media/i2c/jaguar2_drv/jaguar2_drv.c b/drivers/media/i2c/jaguar2_drv/jaguar2_drv.c
--- a/drivers/media/i2c/jaguar2_drv/jaguar2_drv.c
+++ b/drivers/media/i2c/jaguar2_drv/jaguar2_drv.c
@@ -87,6 +87,8 @@
 module_param_named(jaguar2_lane, jaguar2_lane, uint, S_IRUGO);
 static unsigned int chn = 4;
 module_param_named(jaguar2_chn, chn, uint, S_IRUGO);
+unsigned int jaguar2_active = 0xF;
+module_param_named(jaguar2_active, jaguar2_active, uint, S_IRUGO | S_IWUSR);
 static unsigned int init = 0;
 module_param_named(jaguar2_init, init, uint, S_IRUGO);
 static unsigned int fmt = 2;  //0:960H;1:720P 2:1080P 3:960P 4:SH720
diff --git a/drivers/media/i2c/jaguar2_drv/jaguar2_mipi.c b/drivers/media/i2c/jaguar2_drv/jaguar2_mipi.c
--- a/drivers/media/i2c/jaguar2_drv/jaguar2_mipi.c
+++ b/drivers/media/i2c/jaguar2_drv/jaguar2_mipi.c
@@ -44,15 +44,27 @@
 
 void arb_enable2(int dev_num)
 {
+	unsigned char active_en = 0;
+	int ch;
+
 	if((dev_num < 0) || (dev_num > 3))
 	{
 		printk("[DRV] %s input channel Error (%d)\n",__func__, dev_num);
 		return;
 	}
 
+	/* Only enable arbiter channels in jaguar2_active bitmask */
+	for (ch = 0; ch < 4; ch++) {
+		if ((en_param & (0x11 << ch)) && (jaguar2_active & (1 << ch)))
+			active_en |= (0x11 << ch);
+	}
+	if (!active_en)
+		active_en = en_param;
+
 	gpio_i2c_write(jaguar2_i2c_addr[dev_num], 0xff, 0x20);
-	gpio_i2c_write(jaguar2_i2c_addr[dev_num], 0x00, en_param);
-	printk("VDEC_ARBITER_INIT done 0x%X\n", en_param);
+	gpio_i2c_write(jaguar2_i2c_addr[dev_num], 0x00, active_en);
+	printk("[DRV] MIPI TX arbiter enable: 0x%02X (active_mask=0x%X, en_param=0x%X)\n",
+	       active_en, jaguar2_active, en_param);
 }
 
 void arb_disable2(int dev_num)

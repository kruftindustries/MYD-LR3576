+static void arb_rd_t_mode_set(video_input_init *dev_ch_info, unsigned char val)
+{
+	int devnum = dev_ch_info->ch / 4;
+	int ch_local = dev_ch_info->ch % 4;
+	unsigned char reg, rd_t;
+
+	gpio_i2c_write(jaguar2_i2c_addr[devnum], 0xFF, 0x20);
+
+	/* CH1/CH2 in reg 0x20, CH3/CH4 in reg 0x21 (4 bits each) */
+	reg = (ch_local < 2) ? 0x20 : 0x21;
+	rd_t = gpio_i2c_read(jaguar2_i2c_addr[devnum], reg);
+
+	if (ch_local & 1) {
+		/* CH2/CH4: bits [7:4] */
+		rd_t = (rd_t & 0x0F) | (val << 4);
+	} else {
+		/* CH1/CH3: bits [3:0] */
+		rd_t = (rd_t & 0xF0) | (val & 0x0F);
+	}
+
+	gpio_i2c_write(jaguar2_i2c_addr[devnum], reg, rd_t);
+}
+
+static void arb_no_opt_set(int dev_num)
+{
+	gpio_i2c_write(jaguar2_i2c_addr[dev_num], 0xFF, 0x20);
+
+	/*
+	 * ARB_NO_OPT bits [3:0]: suppress MIPI TX for no-video channels.
+	 * HCNT_ERR bits [7:4]: enable H size error detection.
+	 * Set all channels: 0xFF = all HCNT_ERR + all ARB_NO_OPT enabled.
+	 */
+	gpio_i2c_write(jaguar2_i2c_addr[dev_num], 0x3A, 0xFF);
+}
